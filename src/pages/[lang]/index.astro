---
import '../../styles/global.css';
import { ContactBar, FilterSection, Header, LanguageSelector, ModelGrid, ModelModal } from '../../components';
import { categories, countries, i18n, languageRoutes, locations } from '../../lib/site-data';

export const prerender = true;

export function getStaticPaths() {
  return languageRoutes.map((lang) => ({ params: { lang: lang.slug } }));
}

const langParam = (Astro.params.lang ?? 'en').toLowerCase();
const currentLanguageRoute = languageRoutes.find((lang) => lang.slug === langParam) ?? languageRoutes[0];
const defaultLang = currentLanguageRoute.code;
const currentHtmlLang = currentLanguageRoute.html;
const currentLangShort = currentLanguageRoute.short;
const baseUrl = Astro.site?.origin ?? Astro.url.origin;
const t = i18n[defaultLang];
---

<html lang={currentHtmlLang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={`${baseUrl}/${currentLanguageRoute.slug}/`} />
		{languageRoutes.map((lang) => (
			<link rel="alternate" hreflang={lang.hreflang} href={`${baseUrl}/${lang.slug}/`} />
		))}
		<link rel="alternate" hreflang="x-default" href={`${baseUrl}/en/`} />
		<title>VIP Elite Showcase</title>
	</head>
	<body class="min-h-screen pb-24 relative">
		<Header t={t} countries={countries} />
		<LanguageSelector languageRoutes={languageRoutes} defaultLang={defaultLang} currentLangShort={currentLangShort} />
		<FilterSection t={t} locations={locations} categories={categories} />

		<div id="filterSpacer" class="h-[196px]"></div>

		<ModelGrid t={t} models={[]} />
		<ModelModal t={t} />
		<ContactBar t={t} />

		<script define:vars={{ defaultLang, i18n, currentLangShort, currentLanguageRoute }}>
			let currentI18n = i18n[defaultLang];
			let currentCategory = 'spa';
			let currentLanguage = '简体中文';
			let currentVenue = null;
			const countryIdMap = {
				kh: 1,
				my: 2
			};
			const categoryIdMap = {
				spa: 1,
				ktv: 2,
				delivery: 3,
				partyGirls: 4,
				seaTrip: 5
			};
			const locationIdMap = {
				all: null,
				phnom_penh: 1001,
				sihanouk: 1002,
				kuala_lumpur: 2001
			};
			const locationKeyById = {
				1001: 'phnom_penh',
				1002: 'sihanouk',
				2001: 'kuala_lumpur'
			};
			const venueIdMap = {
				spa: [1002101, 1002102, 1002103, 1002104, 1002105, 1002106, 1001101, 1001102, 1001103, 2001101],
				ktv: [1002201, 1002202, 1001201],
				delivery: [],
				partyGirls: [],
				seaTrip: []
			};
			const badgeCodeMap = {
				filterHot: 1,
				filterNew: 2,
				filterRecommend: 3,
				filterYoung: 4
			};
			const badgeTagByCode = {
				1: 'filterHot',
				2: 'filterNew',
				3: 'filterRecommend',
				4: 'filterYoung'
			};

			const modelGrid = document.getElementById('modelGrid');
			const loadMoreButton = document.getElementById('loadMoreButton');
			let loadMoreObserver;
			const initialCountryKey = document.querySelector('.country-tab')?.dataset.country || 'kh';
			let currentCountryId = countryIdMap[initialCountryKey] ?? 1;
			let currentCategoryId = categoryIdMap[currentCategory] ?? 1;
			let currentLocationId = null;
			let currentVenueId = venueIdMap[currentCategory]?.[0] ?? 1002101;
			let currentBadgeCode = badgeCodeMap.filterHot;
			let currentCursor = null;
			let isLoading = false;
			let hasMore = true;
			const pageLimit = 20;

			function getLocationLabel(locationId) {
				const key = locationKeyById[locationId];
				return (key && currentI18n.locations?.[key]) || `${locationId ?? ''}`;
			}

			function resolveBadgeTag(badgeCode) {
				return badgeTagByCode[badgeCode] || 'filterHot';
			}

			function buildProfileCard(profile) {
				const badgeTag = resolveBadgeTag(profile.badge_code);
				const locationKey = locationKeyById[profile.location_id];
				const locationLabel = getLocationLabel(profile.location_id);
				const card = document.createElement('div');
				card.className = 'model-card group cursor-pointer fade-in';
				card.dataset.profileId = `${profile.id}`;
				card.dataset.profileName = profile.nickname || '';
				card.dataset.profileImage = profile.photo_main_url || '';
				card.dataset.profileLocation = locationLabel;
				card.dataset.profileBadge = badgeTag;
				card.dataset.profileAge = profile.age ?? '';
				card.dataset.profileHeight = profile.height_cm ?? '';
				card.dataset.profileWeight = profile.weight_kg ?? '';
				card.dataset.profileBust = profile.bust_size ?? '';
				card.dataset.profileServiceItems = profile.service_items ?? '';
				card.dataset.profileBioDescription = profile.bio_description ?? '';
				card.innerHTML = `
					<div class="relative overflow-hidden rounded-2xl aspect-[3/4] transition-all duration-500 group-hover:scale-[1.03] cinematic-shadow group-hover:neon-glow-purple">
						<img
							src="${profile.photo_main_url || ''}"
							alt="${profile.nickname || ''}"
							class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
							loading="lazy"
						/>
						<div class="absolute inset-0 gradient-overlay"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[var(--purple-deep)]/90 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-300"></div>
						<div class="absolute top-3 right-3">
							<span class="vip-badge tag-${badgeTag} px-3 py-1 rounded-full text-xs font-bold text-black uppercase tracking-wide">
								${currentI18n.labels[badgeTag] ?? badgeTag}
							</span>
						</div>
						<div class="absolute bottom-0 left-0 right-0 p-4">
							<h3 class="text-lg font-bold text-white drop-shadow-lg">${profile.nickname || ''}</h3>
							<div class="flex items-center gap-1.5 text-sm text-[var(--neon-purple)] mt-0.5">
								<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
								</svg>
								<span class="font-medium" data-location="${locationKey || ''}" data-location-label="${locationLabel}">${locationLabel}</span>
							</div>
							<div class="mt-1 text-xs text-white/80 flex flex-wrap gap-x-3 gap-y-1">
								<span>${currentI18n.labels.age}: ${profile.age ?? '-'}</span>
								<span>${currentI18n.labels.height}: ${profile.height_cm ?? '-'}${profile.height_cm ? ' cm' : ''}</span>
								<span>${currentI18n.labels.weight}: ${profile.weight_kg ?? '-'}${profile.weight_kg ? ' kg' : ''}</span>
								<span>${currentI18n.labels.bust}: ${profile.bust_size ?? '-'}</span>
							</div>
						</div>
					</div>
				`;
				return card;
			}

			function clearProfiles() {
				if (!modelGrid) return;
				modelGrid.innerHTML = '';
			}

			function appendProfiles(rows) {
				if (!modelGrid) return;
				rows.forEach((row) => {
					modelGrid.appendChild(buildProfileCard(row));
				});
			}

			function setLoadMoreVisible(visible) {
				if (!loadMoreButton) return;
				loadMoreButton.style.display = visible ? '' : 'none';
				if (!visible) {
					loadMoreObserver?.disconnect();
				}
			}

			function ensureLoadMoreObserver() {
				if (!loadMoreButton) return;
				if (!('IntersectionObserver' in window)) return;
				if (loadMoreObserver) return;
				loadMoreObserver = new IntersectionObserver(
					(entries) => {
						if (entries.some((entry) => entry.isIntersecting)) {
							fetchProfiles();
						}
					},
					{ rootMargin: '200px' }
				);
				loadMoreObserver.observe(loadMoreButton);
			}

			function updateLoadMoreState() {
				if (!loadMoreButton) return;
				const hasAnyProfiles = (modelGrid?.children?.length ?? 0) > 0;
				const shouldShow = hasAnyProfiles && hasMore && !isLoading;
				setLoadMoreVisible(shouldShow);
				loadMoreButton.disabled = isLoading;
				loadMoreButton.classList.toggle('opacity-50', !hasMore);
				if (shouldShow) {
					ensureLoadMoreObserver();
				}
			}

			async function fetchProfiles({ reset = false } = {}) {
				if (isLoading) return;
				if (!hasMore && !reset) return;
				isLoading = true;
				setLoadMoreVisible(false);
				if (reset) {
					currentCursor = null;
					hasMore = true;
					clearProfiles();
				}
				try {
					const payload = {
						lang: defaultLang,
						country_id: currentCountryId,
						category_id: currentCategoryId,
						badge_code: currentBadgeCode,
						is_active: true,
						limit: pageLimit,
						...(currentCursor ? { cursor: currentCursor } : {}),
						...(currentLocationId ? { location_id: currentLocationId } : {}),
						...(currentVenueId ? { venue_id: currentVenueId } : {})
					};
					console.log('profiles payload', payload);
					const response = await fetch('/api/profiles', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload)
					});
					const result = await response.json();
					if (!response.ok || !result.ok) {
						throw new Error(result?.error || 'Request failed');
					}
					const rows = Array.isArray(result.data) ? result.data : [];
					appendProfiles(rows);
					currentCursor = result.next_cursor || null;
					hasMore = Boolean(currentCursor) && rows.length >= pageLimit;
				} catch (error) {
					console.error('Failed to load profiles', error);
				} finally {
					isLoading = false;
					updateLoadMoreState();
				}
			}

			// Country tabs
			document.querySelectorAll('.country-tab').forEach(tab => {
				tab.addEventListener('click', () => {
					const key = tab.dataset.country;
					currentCountryId = countryIdMap[key] ?? currentCountryId;
					document.querySelectorAll('.country-tab').forEach(t => {
						t.classList.remove('neon-underline', 'text-[var(--neon-gold)]');
						t.classList.add('text-[var(--text-secondary)]');
					});
					tab.classList.add('neon-underline', 'text-[var(--neon-gold)]');
					tab.classList.remove('text-[var(--text-secondary)]');
					fetchProfiles({ reset: true });
				});
			});

			const telegramLink = document.getElementById('telegramLink');
			const contactBackdrop = document.getElementById('contactBackdrop');
			const contactSheet = document.getElementById('contactSheet');
			const contactList = document.getElementById('contactList');
			const contactSheetClose = document.getElementById('contactSheetClose');
			let isContactSheetOpen = false;
			let isContactLoading = false;

			function closeContactSheet() {
				if (!contactSheet || !contactBackdrop) return;
				isContactSheetOpen = false;
				contactSheet.classList.add('hidden');
				contactBackdrop.classList.add('hidden');
			}

			function openContactSheet() {
				if (!contactSheet || !contactBackdrop) return;
				isContactSheetOpen = true;
				contactSheet.classList.remove('hidden');
				contactBackdrop.classList.remove('hidden');
			}

			function renderContacts(contacts) {
				if (!contactList) return;
				contactList.innerHTML = '';
				contacts.forEach((item) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className =
						'w-full text-left px-4 py-3 rounded-2xl glass-dark border border-[var(--neon-purple)]/20 hover:border-[var(--neon-gold)]/40 hover:neon-glow-purple transition-all flex items-center justify-between gap-3';
					button.innerHTML = `
						<div class="min-w-0">
							<div class="text-sm font-semibold text-white truncate">${item.contact_name || item.contact_url || ''}</div>
						</div>
						<span class="shrink-0 w-9 h-9 rounded-full bg-[var(--neon-gold)] flex items-center justify-center shadow-lg shadow-black/40">
							<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
							</svg>
						</span>
					`;
					button.addEventListener('click', () => {
						if (item.contact_url) {
							window.open(item.contact_url, '_blank', 'noopener,noreferrer');
							closeContactSheet();
						}
					});
					contactList.appendChild(button);
				});
			}

			async function loadContacts() {
				if (isContactLoading) return;
				isContactLoading = true;
				try {
					const response = await fetch('/api/contact', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ country_id: currentCountryId })
					});
					const result = await response.json();
					if (!response.ok || !result.ok || !Array.isArray(result.data)) {
						throw new Error(result?.error || 'Request failed');
					}
					renderContacts(result.data);
				} catch (error) {
					console.error('Failed to load contact', error);
					if (contactList) {
						contactList.innerHTML = '';
					}
				} finally {
					isContactLoading = false;
				}
			}

			telegramLink?.addEventListener('click', async (event) => {
				event.preventDefault();
				if (isContactSheetOpen) {
					closeContactSheet();
					return;
				}
				openContactSheet();
				await loadContacts();
			});

			contactBackdrop?.addEventListener('click', closeContactSheet);
			contactSheetClose?.addEventListener('click', closeContactSheet);

			const recruitLink = document.getElementById('recruitLink');
			recruitLink?.addEventListener('click', async (event) => {
				event.preventDefault();
				try {
					const response = await fetch('/api/contact', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ contact_type: 0 })
					});
					const result = await response.json();
					const first = Array.isArray(result?.data) ? result.data[0] : null;
					if (!response.ok || !result.ok || !first?.contact_url) {
						throw new Error(result?.error || 'Request failed');
					}
					window.open(first.contact_url, '_blank', 'noopener,noreferrer');
				} catch (error) {
					console.error('Failed to load recruit contact', error);
				}
			});

			// Filter tags
			document.querySelectorAll('.filter-tag').forEach(tag => {
				tag.addEventListener('click', () => {
					const label = tag.dataset.label;
					currentBadgeCode = badgeCodeMap[label] ?? currentBadgeCode;
					document.querySelectorAll('.filter-tag').forEach(t => {
						t.classList.remove('filter-active', 'neon-border-gold', 'neon-glow-gold', 'text-[var(--neon-gold)]');
						t.classList.add('glass');
					});
					tag.classList.add('filter-active', 'neon-border-gold', 'neon-glow-gold', 'text-[var(--neon-gold)]');
					tag.classList.remove('glass');
					fetchProfiles({ reset: true });
				});
			});

			// Category tabs
			document.querySelectorAll('.category-tab').forEach(tab => {
				tab.addEventListener('click', () => {
					const category = tab.dataset.category;
					currentCategory = category;
					currentCategoryId = categoryIdMap[category] ?? currentCategoryId;
					
					document.querySelectorAll('.category-tab').forEach(t => {
						t.classList.remove('neon-border-gold', 'neon-glow-gold', 'text-[var(--neon-gold)]');
						t.classList.add('glass');
					});
					tab.classList.add('neon-border-gold', 'neon-glow-gold', 'text-[var(--neon-gold)]');
					tab.classList.remove('glass');

					updateVenueSection(category);
					fetchProfiles({ reset: true });
				});
			});

			function updateVenueSection(category, dict = currentI18n) {
				const venueSection = document.getElementById('venueSection');
				const venueContainer = document.getElementById('venueContainer');
				const categoryVenues = dict.venues[category] || [];
				if (!categoryVenues.length) {
					venueSection.style.display = 'none';
					currentVenueId = null;
					currentVenue = null;
				} else {
					venueSection.style.display = 'block';
					
					const categoryVenueIds = venueIdMap[category] || [];
					venueContainer.innerHTML = categoryVenues
						.map((venue, index) => {
							const venueId = categoryVenueIds[index] ?? categoryVenueIds[0] ?? currentVenueId;
							return `
								<button class="venue-pill px-6 py-2 rounded-full text-sm font-semibold transition-all whitespace-nowrap ${index === 0 ? 'neon-border-magenta neon-glow-magenta text-[var(--neon-magenta)]' : 'glass hover:neon-glow-purple'}" data-venue="${venue}" data-venue-id="${venueId}">
									${venue}
								</button>
							`;
						})
						.join('');

					currentVenueId = categoryVenueIds[0] ?? currentVenueId;
					currentVenue = categoryVenues[0] ?? null;

					document.querySelectorAll('.venue-pill').forEach(pill => {
						pill.addEventListener('click', () => {
							document.querySelectorAll('.venue-pill').forEach(p => {
								p.classList.remove('neon-border-magenta', 'neon-glow-magenta', 'text-[var(--neon-magenta)]');
								p.classList.add('glass');
							});
							pill.classList.add('neon-border-magenta', 'neon-glow-magenta', 'text-[var(--neon-magenta)]');
							pill.classList.remove('glass');
							currentVenue = pill.dataset.venue;
							currentVenueId = Number(pill.dataset.venueId) || currentVenueId;
							fetchProfiles({ reset: true });
						});
					});
				}
				updateFilterSpacer();
			}

			function updateFilterSpacer() {
				const header = document.querySelector('header');
				const filterSection = document.getElementById('filterSection');
				const spacer = document.getElementById('filterSpacer');
				if (!header || !filterSection || !spacer) return;
				const topOffset = parseFloat(getComputedStyle(filterSection).top) || 0;
				const total = topOffset + filterSection.offsetHeight;
				spacer.style.height = `${total}px`;
			}

			// Location dropdown
			const locationTrigger = document.getElementById('locationTrigger');
			const locationDropdown = document.getElementById('locationDropdown');
			const currentLocation = document.getElementById('currentLocation');

			if (locationTrigger && locationDropdown) {
				const originalParent = locationDropdown.parentElement;
				locationTrigger.addEventListener('click', (e) => {
					e.stopPropagation();
					locationDropdown.classList.toggle('hidden');
					locationDropdown.classList.toggle('dropdown-open');
					if (!locationDropdown.classList.contains('hidden')) {
						const rect = locationTrigger.getBoundingClientRect();
						locationDropdown.style.position = 'fixed';
						locationDropdown.style.left = `${rect.left}px`;
						locationDropdown.style.top = `${rect.bottom + 8}px`;
						locationDropdown.style.zIndex = '70';
						document.body.appendChild(locationDropdown);
					} else if (originalParent && !originalParent.contains(locationDropdown)) {
						originalParent.appendChild(locationDropdown);
					}
				});

				document.querySelectorAll('.location-item').forEach(item => {
					item.addEventListener('click', () => {
						currentLocation.textContent = item.textContent;
						const key = item.dataset.location;
						currentLocationId = locationIdMap[key] ?? null;
						document.querySelectorAll('.location-item').forEach(i => i.classList.remove('language-selected'));
						item.classList.add('language-selected');
						locationDropdown.classList.add('hidden');
						locationDropdown.classList.remove('dropdown-open');
						if (originalParent && !originalParent.contains(locationDropdown)) {
							originalParent.appendChild(locationDropdown);
						}
						fetchProfiles({ reset: true });
					});
				});
			}

			// Initialize venue section
			updateVenueSection('spa');

			// Modal functionality
			const modal = document.getElementById('modelModal');
			const closeModalBtn = document.getElementById('closeModal');
			modelGrid?.addEventListener('click', (event) => {
				const card = event.target.closest('.model-card');
				if (!card) return;
				const image = card.dataset.profileImage || '';
				const name = card.dataset.profileName || '';
				const location = card.dataset.profileLocation || '';
				const badgeTag = card.dataset.profileBadge || 'filterHot';

				const modalImage = document.getElementById('modalImage');
				const modalName = document.getElementById('modalName');
				const modalLocation = document.getElementById('modalLocation');
				const modalTag = document.getElementById('modalTag');
				const modalAge = document.getElementById('modalAge');
				const modalHeight = document.getElementById('modalHeight');
				const modalWeight = document.getElementById('modalWeight');
				const modalBust = document.getElementById('modalBust');
				const modalServiceItems = document.getElementById('modalServiceItems');
				const modalBioDescription = document.getElementById('modalBioDescription');
				if (!modalImage || !modalName || !modalLocation || !modalTag || !modalAge || !modalHeight || !modalWeight || !modalBust || !modalServiceItems || !modalBioDescription) return;

				modalImage.src = image;
				modalImage.alt = name;
				modalName.textContent = name;
				modalLocation.textContent = location;
				modalTag.textContent = currentI18n.labels[badgeTag] || badgeTag;
				modalTag.className = `vip-badge tag-${badgeTag} inline-block px-4 py-1.5 rounded-full text-sm font-bold text-black uppercase tracking-wide mb-4`;
				modalAge.textContent = card.dataset.profileAge ? `${card.dataset.profileAge}` : '-';
				modalHeight.textContent = card.dataset.profileHeight ? `${card.dataset.profileHeight} cm` : '-';
				modalWeight.textContent = card.dataset.profileWeight ? `${card.dataset.profileWeight} kg` : '-';
				modalBust.textContent = card.dataset.profileBust ? `${card.dataset.profileBust}` : '-';
				if (card.dataset.profileServiceItems) {
					const raw = `${card.dataset.profileServiceItems}`;
					const items = raw
						.split(/[,\n]+/)
						.map((value) => value.trim())
						.filter(Boolean);
					modalServiceItems.innerHTML = '';
					const tagClasses = [
						'bg-[var(--neon-gold)]/20 text-[var(--neon-gold)] border-[var(--neon-gold)]/40',
						'bg-[var(--neon-purple)]/20 text-[var(--neon-purple)] border-[var(--neon-purple)]/40',
						'bg-[var(--neon-magenta)]/20 text-[var(--neon-magenta)] border-[var(--neon-magenta)]/40',
						'bg-cyan-400/15 text-cyan-200 border-cyan-300/30'
					];
					items.forEach((text, index) => {
						const span = document.createElement('span');
						span.className = `px-3 py-1 rounded-full text-xs font-semibold border ${tagClasses[index % tagClasses.length]}`;
						span.textContent = text;
						modalServiceItems.appendChild(span);
					});
				} else {
					modalServiceItems.textContent = '-';
				}
				if (card.dataset.profileBioDescription) {
					const rawBio = `${card.dataset.profileBioDescription}`;
					const bioItems = rawBio
						.split(/[,\n]+/)
						.map((value) => value.trim())
						.filter(Boolean);
					modalBioDescription.innerHTML = '';
					const bioTagClasses = [
						'bg-[var(--neon-gold)]/20 text-[var(--neon-gold)] border-[var(--neon-gold)]/40',
						'bg-[var(--neon-purple)]/20 text-[var(--neon-purple)] border-[var(--neon-purple)]/40',
						'bg-[var(--neon-magenta)]/20 text-[var(--neon-magenta)] border-[var(--neon-magenta)]/40',
						'bg-cyan-400/15 text-cyan-200 border-cyan-300/30'
					];
					bioItems.forEach((text, index) => {
						const span = document.createElement('span');
						span.className = `px-3 py-1 rounded-full text-xs font-semibold border ${bioTagClasses[index % bioTagClasses.length]}`;
						span.textContent = text;
						modalBioDescription.appendChild(span);
					});
				} else {
					modalBioDescription.textContent = '-';
				}

				modal.classList.remove('hidden');
				modal.classList.add('flex');
				document.body.style.overflow = 'hidden';
			});

			closeModalBtn.addEventListener('click', () => {
				modal.classList.add('hidden');
				modal.classList.remove('flex');
				document.body.style.overflow = 'auto';
			});

			modal.addEventListener('click', (e) => {
				if (e.target === modal) {
					modal.classList.add('hidden');
					modal.classList.remove('flex');
					document.body.style.overflow = 'auto';
				}
			});

			function applyLanguage(code) {
				const dict = i18n[code] || i18n[defaultLang];
				currentI18n = dict;
				document.documentElement.lang = code;

				document.querySelectorAll('.country-tab').forEach(tab => {
					const key = tab.dataset.country;
					tab.textContent = dict.countries[key] || key;
				});

				document.querySelectorAll('.category-tab').forEach(tab => {
					const key = tab.dataset.category;
					tab.textContent = dict.categories[key] || key;
				});

				document.querySelectorAll('[data-location]').forEach(el => {
					const key = el.dataset.location;
					const mapped = dict.locations[key];
					el.textContent = mapped || el.dataset.locationLabel || key;
				});

				document.querySelectorAll('[data-label]').forEach(el => {
					const key = el.dataset.label;
					el.textContent = dict.labels[key] || el.textContent;
				});

				document.querySelectorAll('.location-item').forEach(item => {
					const key = item.dataset.location;
					item.textContent = dict.locations[key] || key;
				});
				if (currentLocation) {
					const selected = document.querySelector('.location-item.language-selected');
					currentLocation.textContent = selected ? selected.textContent : dict.locations.all;
				}

				updateVenueSection(currentCategory, dict);
			}

			// Language selector dropdown
			const languageTrigger = document.getElementById('languageTrigger');
			const languageDropdown = document.getElementById('languageDropdown');
			const currentLanguageLabel = document.getElementById('currentLanguage');

			if (currentLanguageLabel) {
				currentLanguageLabel.textContent = currentLangShort;
			}

			languageTrigger?.addEventListener('click', (e) => {
				e.stopPropagation();
				languageDropdown.classList.toggle('hidden');
				languageDropdown.classList.toggle('dropdown-open');
			});

			document.querySelectorAll('.language-item').forEach(item => {
				item.addEventListener('click', () => {
					const slug = item.dataset.slug || currentLanguageRoute.slug;
					document.cookie = `lang=${slug}; path=/; max-age=${60 * 60 * 24 * 365}`;
					window.location.href = `/${slug}/`;
				});
			});

			loadMoreButton?.addEventListener('click', () => fetchProfiles());
			setLoadMoreVisible(false);

			applyLanguage(defaultLang);
			fetchProfiles({ reset: true });
			updateFilterSpacer();
			window.addEventListener('resize', updateFilterSpacer);
			window.addEventListener('scroll', () => {
				if (locationDropdown && !locationDropdown.classList.contains('hidden')) {
					locationDropdown.classList.add('hidden');
					locationDropdown.classList.remove('dropdown-open');
					if (originalParent && !originalParent.contains(locationDropdown)) {
						originalParent.appendChild(locationDropdown);
					}
				}
			});

			document.addEventListener('click', () => {
				languageDropdown.classList.add('hidden');
				languageDropdown.classList.remove('dropdown-open');
			});

			// Smooth scroll for horizontal tabs
			const scrollContainers = ['countryScroll', 'categoryScroll', 'venueScroll'];
			scrollContainers.forEach(id => {
				const container = document.getElementById(id);
				if (container) {
					let isDown = false;
					let startX;
					let scrollLeft;

					container.addEventListener('mousedown', (e) => {
						isDown = true;
						startX = e.pageX - container.offsetLeft;
						scrollLeft = container.scrollLeft;
					});

					container.addEventListener('mouseleave', () => {
						isDown = false;
					});

					container.addEventListener('mouseup', () => {
						isDown = false;
					});

					container.addEventListener('mousemove', (e) => {
						if (!isDown) return;
						e.preventDefault();
						const x = e.pageX - container.offsetLeft;
						const walk = (x - startX) * 2;
						container.scrollLeft = scrollLeft - walk;
					});
				}
			});
		</script>
	</body>
</html>
