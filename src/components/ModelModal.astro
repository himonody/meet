---
const { t } = Astro.props;
---

<div id="modelModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/90 backdrop-blur-xl">
  <div class="modal-content glass-dark rounded-3xl max-w-4xl w-full max-h-[90vh] overflow-y-auto scrollbar-hide neon-border-purple neon-glow-purple">
    <div class="relative">
      <button id="closeModal" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full glass hover:neon-glow-magenta flex items-center justify-center transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <div class="grid md:grid-cols-2 gap-6 p-6">
        <div class="relative rounded-2xl overflow-hidden aspect-[3/4]">
          <img id="modalImage" src="" alt="" class="w-full h-full object-cover" />
          <span id="modalTag" class="vip-badge absolute top-4 left-4 z-10 px-4 py-1.5 rounded-full text-sm font-bold text-black uppercase tracking-wide"></span>
        </div>

        <div class="flex flex-col justify-center space-y-6">
          <div>
            <div class="flex items-end justify-between gap-4">
              <div class="min-w-0">
                <h2 id="modalName" class="text-4xl font-bold text-white"></h2>
                <div class="mt-2 flex items-center gap-2 text-[var(--neon-purple)]">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  <span id="modalLocation" class="font-semibold"></span>
                </div>
              </div>
              <div class="shrink-0 text-xs text-white/80 grid grid-cols-2 gap-x-4 gap-y-1">
                <div><span class="text-[var(--text-secondary)]" data-label="age">{t.labels.age}</span>: <span id="modalAge" class="font-semibold text-white"></span></div>
                <div><span class="text-[var(--text-secondary)]" data-label="weight">{t.labels.weight}</span>: <span id="modalWeight" class="font-semibold text-white"></span></div>
                <div><span class="text-[var(--text-secondary)]" data-label="bust">{t.labels.bust}</span>: <span id="modalBust" class="font-semibold text-white"></span></div>
                <div><span class="text-[var(--text-secondary)]" data-label="height">{t.labels.height}</span>: <span id="modalHeight" class="font-semibold text-white"></span></div>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <div>
              <div class="text-sm font-semibold text-white" data-label="service">{t.labels.service}</div>
              <div id="modalServiceItems" class="mt-2 flex flex-wrap gap-2"></div>
            </div>
            <div>
              <div class="text-sm font-semibold text-white" data-label="bio">{t.labels.bio}</div>
              <div id="modalBioDescription" class="mt-2 flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
